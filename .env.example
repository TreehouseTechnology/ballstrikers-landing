# ---- App ----
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# ---- Supabase (required) ----
# Create project, then populate URL and service role key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Resend (required for confirmation email) ----
# Existing Resend account can be used.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@ballstrikers.app

# ---- CAPTCHA / Bot Protection ----
# Recommended: Cloudflare Turnstile (lower cost, easy edge use).
# Add site key (public) and secret key (server verify).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- PostHog (self-hosted) ----
# Set these to your self-hosted instance values.
# Example host: https://ph.ballstrikers.app
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_PERSONAL_API_KEY=

# ---- Optional hardening ----
WAITLIST_RATE_LIMIT_WINDOW_MS=60000
WAITLIST_RATE_LIMIT_MAX=10

# ---- CI/CD placeholders (reference for GitHub Actions + Amplify) ----
# These are not read by app runtime directly. Keep real values in:
# - GitHub Actions Variables/Secrets
# - AWS Amplify environment variable settings
AWS_REGION=
AMPLIFY_APP_ID=
AMPLIFY_BRANCH=main
AWS_AMPLIFY_DEPLOY_ROLE_ARN=
